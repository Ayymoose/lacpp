#!/bin/sh

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Regex: ZENG-123: anything
pattern="^ZENG-[0-9]+: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo "✔ Expected format: ZENG-X: your message"
  echo ""
  exit 1
fi

exit 0
